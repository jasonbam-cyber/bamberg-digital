# Site
NEXT_PUBLIC_SITE_URL=https://www.bambergdigital.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=bambergdigital.com

# Contact form — Gmail SMTP via Google Workspace App Password
# Generate App Password at: https://myaccount.google.com/apppasswords
SMTP_USER=info@bambergdigital.com
SMTP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Contact form fallback webhook (optional — used if SMTP vars not set)
CONTACT_WEBHOOK_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Square (Bamberg Digital billing)
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=production
