# Site
NEXT_PUBLIC_SITE_URL=https://www.bambergdigital.com

# Contact form — Gmail SMTP via Google Workspace App Password
# Generate App Password at: https://myaccount.google.com/apppasswords
# SMTP_USER is the authenticated sender (must match the account that owns the app password)
SMTP_USER=jason@bambergdigital.com
SMTP_APP_PASSWORD=<google-app-password-no-spaces>
# CONTACT_TO_EMAIL is the delivery recipient (can differ from the auth user)
CONTACT_TO_EMAIL=info@bambergdigital.com

# Contact form fallback webhook (optional — used if SMTP vars not set)
CONTACT_WEBHOOK_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Square (Bamberg Digital billing)
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=production
